//@version=5
// ALPHAEDGE V13.0.6 – AE INDICATOR (SEPARATE PANE)
// Displays TPS scores and metrics in separate pane below chart
// Data received from AlphaEdge Bot via Webhook
// Watermark: AlphaEdge AE Indicator v13.0.6
// Author: AlphaEdge AI Strategist (Agent 16 + Agent 30)
// Date: June 25, 2026

indicator("AlphaEdge AE Indicator", overlay=false)

// ============================================
// SECTION 1: USER INPUTS
// ============================================

// TPS Thresholds
min_tps = input.float(70, "Min TPS Score", step=1, minval=50, maxval=90)

// Refresh Rate
refresh = input.int(60, "Refresh Rate (seconds)", step=10, minval=10, maxval=300)

// ============================================
// SECTION 2: CORE INDICATORS (Same as Strategy)
// ============================================

// EMAs
ema20 = ema(close, 20)
ema50 = ema(close, 50)
ema200 = ema(close, 200)

// RSI (14)
rsi_val = rsi(close, 14)

// MACD
[macd_line, signal_line, hist_line] = macd(close, 12, 26, 9)

// ADX (Trend Strength)
adx_val = adx(high, low, close, 14)

// Volume
volume_spike = volume > sma(volume, 20) * 1.5

// ============================================
// SECTION 3: TICKER PERFORMANCE SCORE (TPS)
// ============================================

// TPS Calculation (0-100)
tps_technical = (rsi_val >= 60 and rsi_val <= 75 ? 10 : 0) +
                (macd_line > signal_line ? 10 : 0) +
                (close > ema20 and ema20 > ema50 ? 10 : 0)

tps_volume = (volume_spike ? 15 : 0) +
             ((volume / ema(volume, 20) * 100) >= 20 ? 10 : 0)

tps_momentum = (close > close[14] * 1.1 ? 10 : 0)

tps_macro = 10  // Placeholder
tps_sentiment = 3  // Stage 1
tps_onchain = 5  // Placeholder

tps_robustness = (close > ema20 and close > ema50 and close > ema200 ? 3 : 0) +
                 (adx_val > 25 ? 2 : 0)

tps_score = tps_technical + tps_volume + tps_momentum + 
            tps_macro + tps_sentiment + tps_onchain + tps_robustness

tps_normalized = min(tps_score, 100)

// ============================================
// SECTION 4: TPS GAUGE DISPLAY
// ============================================

// Create gauge-like display for TPS
plot(tps_normalized, color=color.blue, linewidth=2, title="TPS Score")

// TPS Components (stacked for visibility)
plot(tps_technical, color=color.green, linewidth=1, title="Technical")
plot(tps_volume, color=color.orange, linewidth=1, title="Volume")
plot(tps_momentum, color=color.purple, linewidth=1, title="Momentum")
plot(tps_macro, color=color.yellow, linewidth=1, title="Macro")
plot(tps_sentiment, color=color.pink, linewidth=1, title="Sentiment")
plot(tps_onchain, color=color.teal, linewidth=1, title="On-chain")
plot(tps_robustness, color=color.gray, linewidth=1, title="Robustness")

// ============================================
// SECTION 5: STATUS LABEL
// ============================================

if (barstate.islast)
    // Determine TPS status
    tps_color = tps_normalized >= 82 ? color.green :
                tps_normalized >= 70 ? color.yellow :
                tps_normalized >= 50 ? color.orange : color.red
    
    status_text = tps_normalized >= 82 ? "🟢 STRONG SETUP" :
                  tps_normalized >= 70 ? "🟡 MONITOR" :
                  tps_normalized >= 50 ? "🟠 WATCH" : "🔴 AVOID"
    
    // Display status on chart
    label.new(bar_index, 100,
         "📊 ALPHAEDGE INDICATOR\n" +
         "─────────────────────\n" +
         "TPS Score: " + str.tostring(tps_normalized, "#") + "/100\n" +
         "Status: " + status_text + "\n" +
         "─────────────────────\n" +
         "Technical: " + str.tostring(tps_technical, "#") + "/30\n" +
         "Volume:    " + str.tostring(tps_volume, "#") + "/25\n" +
         "Momentum:  " + str.tostring(tps_momentum, "#") + "/20\n" +
         "Macro:     " + str.tostring(tps_macro, "#") + "/10\n" +
         "Sentiment: " + str.tostring(tps_sentiment, "#") + "/5\n" +
         "On-chain:  " + str.tostring(tps_onchain, "#") + "/5\n" +
         "Robust:    " + str.tostring(tps_robustness, "#") + "/5",
         color=color.new(color.black, 80),
         textcolor=color.white,
         style=label.style_label_left,
         size=size.small)

// ============================================
// SECTION 6: WATERMARK
// ============================================

if (barstate.islast)
    label.new(bar_index, 0,
         "AlphaEdge AE Indicator v13.0.6",
         color=color.new(color.white, 60),
         textcolor=color.white,
         style=label.style_label_left,
         size=size.small)

// ============================================
// SECTION 7: ALERTS
// ============================================

alertcondition(tps_normalized >= 82, title="TPS ≥82 Detected",
     message="AE Indicator: TPS ≥82 detected. Strong setup.")

alertcondition(tps_normalized <= 68, title="TPS ≤68 Detected",
     message="AE Indicator: TPS ≤68 detected. Consider exit.")

// ============================================
// SECTION 8: REFERENCE LINES
// ============================================

// Entry/Exit threshold lines
hline(82, color=color.green, linestyle=hline.style_dashed, linewidth=1, title="Entry Threshold")
hline(68, color=color.red, linestyle=hline.style_dashed, linewidth=1, title="Exit Threshold")
hline(50, color=color.gray, linestyle=hline.style_dotted, linewidth=1, title="Neutral")
